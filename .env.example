# =============================================================================
# Yever Recovery Bridge — variáveis de ambiente
# Copie este arquivo para .env e preencha. NUNCA commitar .env.
# =============================================================================

# Porta em que o servidor Express vai escutar
PORT=3000

# -----------------------------------------------------------------------------
# Yever
# -----------------------------------------------------------------------------
# Token da API da Yever (formato Sanctum: "<id>|<hash>"). Usado para chamadas
# OUTBOUND para a API da Yever (ex.: consultar status de um checkout).
YEVER_API_TOKEN=

# Segredo do webhook da Yever — usado para validar a assinatura HMAC dos
# webhooks que a Yever envia para nós. Ainda NÃO é validado nesta Fase 1.
YEVER_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Octadesk (FASE 1 — usado para recuperação de carrinho abandonado)
# -----------------------------------------------------------------------------
# Chave da API da Octadesk — vai no header X-API-KEY.
OCTADESK_API_KEY=

# Base URL da API da Octadesk (sem barra no final). Ex.:
# https://o223219-9a0.api002.octadesk.services
OCTADESK_BASE_URL=

# Número oficial de origem (formato +55DDDNNNNNNNN).
OCTADESK_ORIGIN_PHONE=+5511923732847

# IDs dos templates aprovados para recuperação em cascata
# Estes templates devem ser aprovados pela Octadesk para WhatsApp
OCTADESK_TEMPLATE_REC_1H=
OCTADESK_TEMPLATE_REC_24H=
OCTADESK_TEMPLATE_REC_36H=

# Ativar modo "dry-run": se true, simula envio sem chamar Octadesk
# Útil para testes. Deixe em branco ou false em produção.
DRY_RUN=false

# Intervalo de execução do job de recuperação em minutos
# Padrão: 60 (1x por hora). Mínimo recomendado: 30
JOB_INTERVAL_MINUTES=60

# -----------------------------------------------------------------------------
# Banco (FASE 1 — PostgreSQL via Railway ou outro provedor)
# Formato: postgresql://user:password@host:port/database
# Ex.: postgresql://postgres:senha@db.railway.internal:5432/mydb
# # DATABASE_URL=
DATABASE_URL=
