# =============================================================================
# Yever Recovery Bridge — variáveis de ambiente
# Copie este arquivo para .env e preencha. NUNCA commitar .env.
# =============================================================================

# Porta em que o servidor Express vai escutar
PORT=3000

# -----------------------------------------------------------------------------
# Yever
# -----------------------------------------------------------------------------
# Token da API da Yever (formato Sanctum: "<id>|<hash>"). Usado para chamadas
# OUTBOUND para a API da Yever (ex.: consultar status de um checkout).
YEVER_API_TOKEN=

# Segredo do webhook da Yever — usado para validar a assinatura HMAC dos
# webhooks que a Yever envia para nós. Ainda NÃO é validado nesta Fase 1.
YEVER_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Octadesk (não é usado na Fase 1; reservado para a Fase 2)
# -----------------------------------------------------------------------------
# Chave da API da Octadesk — vai no header X-API-KEY.
OCTADESK_API_KEY=

# Base URL da API da Octadesk (sem barra no final). Ex.:
# https://o223219-9a0.api002.octadesk.services
OCTADESK_BASE_URL=

# Número oficial de origem (formato +55DDDNNNNNNNN).
OCTADESK_ORIGIN_PHONE=+5511923732847

# ID/nome do template aprovado para a recuperação de 1h.
OCTADESK_TEMPLATE_REC_1H=

# -----------------------------------------------------------------------------
# Banco (não é usado na Fase 1; reservado para a Fase 2)
# -----------------------------------------------------------------------------
DATABASE_URL=
